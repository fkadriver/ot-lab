# OT Lab direnv environment
# Automatically sourced on `cd` into this directory when direnv is installed.
# Install direnv: https://direnv.net  then `direnv allow` in this directory.

PATH_add .
PATH_add scripts

export LAB_DIR="$PWD"

echo ""
echo "  OT Lab environment loaded.  Run 'lab.sh' to open the menu."
echo ""
